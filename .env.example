# Foundry - Bambu Lab AI Print Management Suite

# API Auth
FOUNDRY_API_TOKEN=change-me-to-a-secure-random-string

# Printer Config (add via Settings UI, but defaults here for first printer)
BAMBU_PRINTER_IP=192.168.1.100
BAMBU_PRINTER_SERIAL=YOUR_SERIAL
BAMBU_PRINTER_ACCESS_CODE=YOUR_LAN_ACCESS_CODE

# Google Gemini API
GEMINI_API_KEY=AIzaSy...

# Notifications (ntfy.sh)
NTFY_TOPIC=foundry-prints
NTFY_SERVER=https://ntfy.sh

# MakerWorld / Bambu Lab Account (for downloading .3mf files)
MAKERWORLD_EMAIL=
MAKERWORLD_PASSWORD=

# Reddit API (for knowledge base scraper)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=foundry/1.0
REDDIT_LOGIN_USER=
REDDIT_LOGIN_PASSWORD=

# Database
DATABASE_URL=sqlite+aiosqlite:///storage/foundry.db

# OrcaSlicer path
ORCASLICER_PATH=/Applications/OrcaSlicer.app/Contents/MacOS/orca-slicer

# OpenSCAD path
OPENSCAD_PATH=/usr/local/bin/openscad

# BlenderMCP (poly-mcp) — enables Blender as generation backend
BLENDER_MCP_URL=http://localhost:8000
BLENDER_MCP_ENABLED=false
BLENDER_EXPORT_DIR=

# Environment
FOUNDRY_ENV=development
